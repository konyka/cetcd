prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib64
includedir=/usr/local/include

Name: libuv-static
Version: 1.52.2
Description: multi-platform support library with a focus on asynchronous I/O.
URL: http://libuv.org/

Libs: -L${libdir} -l:libuv.a -lpthread -ldl -lrt -lm
Cflags: -I${includedir}
